# Copy to .env and fill in your value before starting Traefik.
# Never commit .env — it is gitignored.

ACME_EMAIL=

# Cloudflare API token for nexdue.app DNS-01 challenge
# Create at dash.cloudflare.com → My Profile → API Tokens
# Permissions: Zone → DNS → Edit, scoped to nexdue.app only
CF_DNS_API_TOKEN_NEXDUE=
